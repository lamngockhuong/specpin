---
/*
 * Changelog route (/changelog).
 *
 * Renders the browser extension's changelog on the site. The content is pulled
 * from apps/extension/CHANGELOG.md at BUILD TIME (release-please owns that file),
 * so a released extension version shows up here on the next site deploy. The
 * web-deploy workflow lists apps/extension/CHANGELOG.md in its paths filter so a
 * release triggers a redeploy.
 *
 * We render inside StarlightPage to inherit the site shell (nav, theme toggle,
 * footer, prose styling) and light/dark parity for free, rather than hand-rolling
 * a bare page. The changelog is semi-external (release-please renders
 * conventional-commit subjects from a public repo), so `set:html` is used only on
 * SANITIZED output: the custom marked renderer below neutralizes any raw HTML to
 * text, leaving legitimate Markdown intact. See that renderer for the rationale.
 */
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { Marked } from "marked";

// Resolve from the build cwd (apps/web), not import.meta.url: this frontmatter is
// bundled by Vite, so import.meta.url points at the output chunk, not this source
// file. `astro dev` and `astro build` both run with cwd = apps/web, so the source
// is two levels up then into apps/extension. (Matches TabRest's changelog page.)
const source = resolve(process.cwd(), "../../apps/extension/CHANGELOG.md");
// readFileSync throws ENOENT (naming the path) if the source moves, so a broken
// path fails the build loudly instead of shipping an empty page.
// Drop the leading `# Changelog` heading: StarlightPage already renders the page
// title as the h1, so keeping the markdown's own top-level heading would produce
// a duplicate. release-please owns CHANGELOG.md, so we strip it here at render
// time rather than editing the generated file.
const raw = readFileSync(source, "utf-8").replace(/^\s*#\s+.*(\r?\n)+/, "");

// The changelog is generated by release-please from conventional-commit subjects,
// i.e. semi-external text on a PUBLIC repo. Neutralize any raw HTML in it to text
// so an injected tag in a commit subject cannot execute on the live site (defense
// in depth behind maintainer merge review). Legitimate Markdown (links, lists) is
// unaffected. No sanitizer dependency needed - we just refuse to emit raw HTML.
const escapeHtml = (s: string) =>
  s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const md = new Marked({
  renderer: {
    html: (token: string | { text: string }) =>
      escapeHtml(typeof token === "string" ? token : token.text),
  },
});
const html = await md.parse(raw);
---

<StarlightPage
  frontmatter={{
    title: "Changelog",
    description: "Release notes for the Specpin browser extension.",
    tableOfContents: false,
    pagefind: false,
  }}
>
  <p>
    Release notes for the Specpin browser extension. See all releases on{" "}
    <a
      href="https://github.com/lamngockhuong/specpin/releases"
      rel="noopener noreferrer"
      target="_blank">GitHub</a
    >.
  </p>
  <div class="sl-markdown-content" set:html={html} />
</StarlightPage>
