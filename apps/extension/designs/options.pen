          }
        },
        {
          "value": "#10463E",
          "theme": {
            "mode": "dark"
          }
        }
      ]
    },
    "grad-bottom": {
      "type": "color",
      "value": [
        {
          "value": "#F2FBF9",
          "theme": {
            "mode": "light"
          }
        },
        {
          "value": "#04130F",
          "theme": {
            "mode": "dark"
          }
        }
      ]
    },
    "accent-glow": {
      "type": "color",
      "value": [
        {
          "value": "#2DD4BF33",
          "theme": {
            "mode": "light"
          }
        },
        {
          "value": "#2DD4BF66",
          "theme": {
            "mode": "dark"
          }
        }
      ]
    },
    "accent-on": {
      "type": "color",
      "value": "#04221E"
    }
  },
  "themes": {
    "mode": [
      "light",
      "dark"
    ]
  }
}
