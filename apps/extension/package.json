{
  "name": "@specpin/extension",
  "version": "0.0.14",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "sync-css-tokens": "node designs/sync-css-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@specpin/api-client": "workspace:*",
    "@specpin/fingerprint-core": "workspace:*",
    "@specpin/spec-schema": "workspace:*",
    "webextension-polyfill": "0.12.0"
  },
  "devDependencies": {
    "wxt": "0.20.27"
  }
}
