{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".output/**",
        "src/types.gen.ts",
        "src/validators.gen.cjs",
        "src/validators.gen.d.cts"
      ]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "schema-validate": {
      "dependsOn": ["^build"]
    }
  }
}
