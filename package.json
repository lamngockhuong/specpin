{
  "name": "specpin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "schema-validate": "turbo run schema-validate",
    "format": "biome format --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "happy-dom": "^16.5.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
