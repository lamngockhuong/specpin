{
  "name": "specpin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "schema-validate": "turbo run schema-validate",
    "format": "biome format --write ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "happy-dom": "20.10.6",
    "turbo": "2.10.2",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
