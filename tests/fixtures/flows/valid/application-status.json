{
  "$schema": "https://specpin.ohnice.app/schema/v1.json",
  "version": "1.0",
  "flows": [
    {
      "id": "application-status",
      "object": { "en": "Application" },
      "description": { "en": "Lifecycle of a loan application" },
      "states": [
        { "id": "draft", "label": { "en": "Draft" }, "kind": "initial" },
        { "id": "submitted", "label": { "en": "Submitted" }, "specId": "app-submit-btn" },
        { "id": "approved", "label": { "en": "Approved" }, "kind": "terminal" }
      ],
      "transitions": [
        {
          "id": "t1",
          "from": "draft",
          "to": "submitted",
          "trigger": { "en": "Submit" },
          "specId": "app-submit-btn",
          "source": "manual"
        },
        {
          "id": "t2",
          "from": "submitted",
          "to": "approved",
          "trigger": { "en": "Approve" },
          "guard": "role == admin",
          "role": "admin"
        }
      ]
    }
  ]
}
