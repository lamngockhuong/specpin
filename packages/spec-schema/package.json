{
  "name": "@specpin/spec-schema",
  "version": "0.0.6",
  "description": "Specpin spec file JSON Schema (v1) with generated TypeScript types and ajv validators.",
  "license": "Apache-2.0",
  "author": "Lam Ngoc Khuong",
  "homepage": "https://specpin.ohnice.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lamngockhuong/specpin.git",
    "directory": "packages/spec-schema"
  },
  "bugs": {
    "url": "https://github.com/lamngockhuong/specpin/issues"
  },
  "keywords": [
    "specpin",
    "json-schema",
    "spec",
    "ui-spec",
    "ajv"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema/v1.json": "./schema/v1.json"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "gen": "tsx scripts/gen-types.ts",
    "build": "tsx scripts/gen-types.ts && tsc -p tsconfig.json && tsx scripts/copy-gen-assets.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "schema-validate": "tsx scripts/validate-fixtures.ts"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "json-schema-to-typescript": "15.0.4",
    "tsx": "4.23.1"
  }
}
